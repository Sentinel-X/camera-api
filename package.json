{
  "name": "camera-api",
  "version": "0.1.0",
  "description": "TypeScript library starter for camera-related APIs.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --import tsx ./node_modules/mocha/bin/mocha.js \"test/**/*.spec.ts\"",
    "release": "semantic-release",
    "prepublishOnly": "npm test"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "keywords": [
    "typescript",
    "library",
    "camera"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^11.1.0",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/npm": "^11.0.3",
    "@semantic-release/release-notes-generator": "^12.1.0",
    "@types/chai": "^5.2.1",
    "@types/mocha": "^10.0.10",
    "@types/node-fetch": "^2.6.13",
    "chai": "^5.2.1",
    "mocha": "^11.1.0",
    "nock": "^14.0.2",
    "rimraf": "^6.0.1",
    "semantic-release": "^23.1.1",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "digest-fetch": "github:Sentinel-X/digest-fetch#2.0.5",
    "fast-xml-parser": "^5.5.10",
    "fetch-retry": "^6.0.0",
    "node-fetch": "^2.7.0"
  }
}
